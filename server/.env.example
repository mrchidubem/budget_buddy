# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/budget_buddy
MONGODB_URI_PROD=

# Server
NODE_ENV=development
PORT=5000

# Auth (use long random strings in production)
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS — comma-separated frontend URLs (production)
CORS_ORIGIN=http://localhost:5173

# Email
# Choose one provider. If none is configured, development logs simulated emails.
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Budget Buddy

# Recommended free option: Brevo (300/day free plan)
BREVO_API_KEY=

# Alternative: Resend
RESEND_API_KEY=

# Alternative: SendGrid
SENDGRID_API_KEY=

# Immediate dev/demo fallback: Gmail or any SMTP provider
# Gmail requires a Google App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
